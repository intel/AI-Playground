{
  "name": "ai-playground",
  "private": true,
  "version": "3.0.3-beta",
  "scripts": {
    "dev": "cross-env VITE_DEBUG_TOOLS=\"true\" VITE_PLATFORM_TITLE=\"from Intel®\" AIPG_DEBUGGING_PORT=\"29222\" vite",
    "preview": "vite preview",
    "fetch-external-resources": "node --experimental-strip-types ./build/scripts/fetch-external-resources.mts",
    "patch-nsis-files": "node --experimental-strip-types ./build/scripts/patch-nsis-template.mts",
    "build": "npm run patch-nsis-files && cross-env-shell VITE_PLATFORM_TITLE=\"from Intel®\" \"vue-tsc && vite build && electron-builder --config build/build-config.json --win --x64 --publish never\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:eslint": "eslint . --fix",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "type-check": "vue-tsc --noEmit",
    "lint:ci": "eslint .",
    "format:ci": "prettier --check ."
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@ai-sdk/vue": "^3.0.116",
    "@google/model-viewer": "^4.1.0",
    "@heroicons/vue": "^2.2.0",
    "@langchain/classic": "^1.0.22",
    "@langchain/community": "^1.1.22",
    "@langchain/core": "^1.1.31",
    "@langchain/openai": "^1.2.12",
    "@radix-icons/vue": "^1.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "ai": "^6.0.116",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dompurify": "^3.3.3",
    "extract-zip": "^2.0.1",
    "get-port": "^7.1.0",
    "koffi": "^2.15.2",
    "langchain": "^1.2.30",
    "lucide-vue-next": "^0.577.0",
    "mammoth": "^1.11.0",
    "marked": "^17.0.4",
    "marked-shiki": "^1.2.1",
    "ollama": "^0.6.3",
    "partysocket": "^1.1.16",
    "pdf-parse": "1.1.4",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.9.1",
    "remove": "^0.1.5",
    "shiki": "^4.0.2",
    "sudo-prompt": "^9.2.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "uint8array-extras": "^1.5.0",
    "unplugin-auto-import": "^21.0.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.30",
    "word-extractor": "^1.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/dompurify": "^3.2.0",
    "@types/exif": "^0.6.5",
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/devtools": "^8.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "adm-zip": "^0.5.16",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "eslint": "^10.0.3",
    "eslint-plugin-oxlint": "^1.51.0",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "overrides": {
    "pdf-parse": "1.1.4",
    "three": "^0.183.2",
    "file-type": "^21.3.1"
  },
  "debug": {
    "env": {
      "VITE_DEV_SERVER_HOSTNAME": "127.0.0.1",
      "VITE_DEV_SERVER_PORT": 25413,
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:25413",
      "VSCODE_DEBUG": 1
    }
  },
  "main": "dist/main/main.js"
}
