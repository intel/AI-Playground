{
  "name": "ai-playground",
  "private": true,
  "version": "3.1.0-alpha",
  "scripts": {
    "dev": "cross-env VITE_DEBUG_TOOLS=\"true\" VITE_PLATFORM_TITLE=\"from Intel®\" AIPG_DEBUGGING_PORT=\"29222\" vite",
    "preview": "vite preview",
    "fetch-external-resources": "node --experimental-strip-types ./build/scripts/fetch-external-resources.mts",
    "patch-nsis-files": "node --experimental-strip-types ./build/scripts/patch-nsis-template.mts",
    "build": "npm run patch-nsis-files && cross-env-shell VITE_PLATFORM_TITLE=\"from Intel®\" \"vue-tsc && vite build && electron-builder --config build/build-config.json --win --x64 --publish never && node --experimental-strip-types ./build/scripts/warn-bundled-wheels.mts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:eslint": "eslint . --fix",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "type-check": "vue-tsc --noEmit",
    "lint:ci": "eslint .",
    "format:ci": "prettier --check .",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.36",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@ai-sdk/vue": "^3.0.159",
    "@google/model-viewer": "^4.2.0",
    "@heroicons/vue": "^2.2.0",
    "@langchain/classic": "^1.0.30",
    "@langchain/community": "^1.1.22",
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-icons/vue": "^1.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vueuse/core": "^14.2.1",
    "ai": "6.0.159",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dompurify": "^3.4.0",
    "driver.js": "^1.4.0",
    "extract-zip": "^2.0.1",
    "get-port": "^7.2.0",
    "highlight.js": "^11.11.1",
    "koffi": "^2.15.6",
    "langchain": "^1.3.2",
    "lucide-vue-next": "^1.0.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.2",
    "marked-highlight": "^2.2.4",
    "partysocket": "^1.1.16",
    "pdf-parse": "1.1.4",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.9.6",
    "remove": "^0.1.5",
    "sudo-prompt": "^9.2.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.182.0",
    "uint8array-extras": "^1.5.0",
    "unplugin-auto-import": "^21.0.0",
    "vee-validate": "^5.0.0-beta.1",
    "vue": "^3.5.32",
    "word-extractor": "^1.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/dompurify": "^3.2.0",
    "@types/exif": "^0.6.5",
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "adm-zip": "^0.5.17",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "eslint": "^10.2.0",
    "eslint-plugin-oxlint": "^1.60.0",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "langsmith": "^0.5.19",
    "@langchain/community": {
      "pdf-parse": "1.1.4",
      "@browserbasehq/stagehand": "^3.2.1",
      "openai": "^6.34.0"
    }
  },
  "debug": {
    "env": {
      "VITE_DEV_SERVER_HOSTNAME": "127.0.0.1",
      "VITE_DEV_SERVER_PORT": 25413,
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:25413",
      "VSCODE_DEBUG": 1
    }
  },
  "main": "dist/main/main.js"
}
