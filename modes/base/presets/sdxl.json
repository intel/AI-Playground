      { "label": "0.5", "totalPixels": 495616 },
      { "label": "0.8", "totalPixels": 802816 },
      { "label": "1.0", "totalPixels": 1048576 }
    ],
    "aspectRatios": ["21/9", "16/9", "3/2", "4/3", "1/1", "3/4", "2/3", "9/16", "9/21"]
