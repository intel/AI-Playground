{
  "type": "comfy",
  "name": "Wan2.2-14B-i2v",
  "description": "Image to Video generation using Wan 2.2 14B (high noise + low noise expert models). Recommended for systems with discrete GPUs and high vRAM.",
  "extendedDescription": {
    "Fast": "Generate short video clips from a starting image using the Lightx2v 4-step LoRAs. Load an image and set the aspect ratio to match the ratio of the image. Keep resolution to 0.25-0.5MP. Write a prompt that describes the core subject of the video in detail. Describe the action of the subject. Describe the camera movement. Describe the background of the scene.",
    "Quality": "Generate higher quality short video clips from a starting image using the full 20-step two-stage diffusion. Slower but produces better motion fidelity than the Fast variant. Load an image, write a descriptive prompt describing subject, action, camera movement and background, then generate."
  },
  "displayPriority": 250,
  "tags": ["dGPU", "high vRAM", "Wan 2.2"],
  "backend": "comfyui",
  "category": "create-videos",
  "resolutionConfig": {
    "megapixels": [
      { "label": "0.25", "totalPixels": 262144 },
      { "label": "0.5", "totalPixels": 495616 },
      { "label": "0.8", "totalPixels": 802816 }
