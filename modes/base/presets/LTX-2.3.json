{
  "type": "comfy",
  "name": "LTX-2.3",
  "description": "Text and Image to Video generation using Lightricks LTX-2.3 (22B) with audio. Single-stage distilled pipeline. Recommended for systems with discrete GPUs and high vRAM.",
  "extendedDescription": {
    "Text2Video": "Generate video clips from a text description. Use a very descriptive prompt that describes the core subject of the video including what words are spoken or type of music is played. Describe the action that transpires, and any camera movement and background of the scene.",
    "Image2Video": "Generate video clips from an Image and text description. Use a very descriptive prompt that describes the core subject of the video including what words are spoken or type of music is played. Describe the action that transpires, and any camera movement and background of the scene."
  },
  "displayPriority": 350,
  "tags": ["LTX Video", "LTX 2.3", "high-vram"],
  "backend": "comfyui",
  "category": "create-videos",
  "toolCategory": "create-videos",
  "mediaType": "video",
  "toolInstructions": "Use this workflow to generate a short video clip with audio from a text prompt (text-to-video). Write a detailed prompt describing the subject, its action, any spoken words or music, the camera movement, and the background. Resource-intensive (high VRAM); only use when the user explicitly asks for a video. This tool does NOT take an input image - to animate an existing image into a video, use an image-to-video workflow (e.g. Wan2.2-14B-i2v) instead.",
  "resolutionConfig": {
    "megapixels": [
      { "label": "0.1", "totalPixels": 102400 },
      { "label": "0.25", "totalPixels": 262144 },
      { "label": "0.35", "totalPixels": 366025 },
